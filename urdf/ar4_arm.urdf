<?xml version="1.0"?>
<robot name="ar4">

  <!-- Fixed anchor to world for RViz visualization -->
  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       LINKS — simple cylinder geometry per link.
       Visuals are in each link's LOCAL frame;
       the joint origins below place them correctly
       in world space.
       ═══════════════════════════════════════════ -->

  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_1">
    <visual>
      <geometry><cylinder radius="0.04" length="0.16977"/></geometry>
      <origin xyz="0 0 -0.084885" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.16977"/></geometry>
      <origin xyz="0 0 -0.084885" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_2">
    <visual>
      <geometry><cylinder radius="0.025" length="0.305"/></geometry>
      <origin xyz="0 -0.1525 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.025" length="0.305"/></geometry>
      <origin xyz="0 -0.1525 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_3">
    <visual>
      <geometry><cylinder radius="0.022" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.022" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_4">
    <visual>
      <geometry><cylinder radius="0.02" length="0.22263"/></geometry>
      <origin xyz="0 0 -0.111315" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.02" length="0.22263"/></geometry>
      <origin xyz="0 0 -0.111315" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="link_5">
    <visual>
      <geometry><cylinder radius="0.018" length="0.041"/></geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.018" length="0.041"/></geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="link_6">
    <visual>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- End-effector reference frame — no geometry, no motion -->
  <link name="ee_link"/>

  <!-- ═══════════════════════════════════════════
       JOINTS — exact AR4 MK3 kinematic values
       from ar4_ros_driver / annin_ar4_description
       ═══════════════════════════════════════════ -->

  <!-- joint_1: base rotation
       180° X-flip encodes the inverted-mount convention;
       the arm hangs/folds from here at zero position.  -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="3.14159 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="2.9671" velocity="1.0472" effort="10"/>
  </joint>

  <!-- joint_2: shoulder
       xyz offset = shoulder pivot is 64.2 mm in Y and 169.77 mm below base.
       rpy = 90° X then -90° Z reorients the frame for the upper-arm link. -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0.0642 -0.16977" rpy="1.5708 0 -1.5708"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.7330" upper="1.5708" velocity="1.0472" effort="10"/>
  </joint>

  <!-- joint_3: elbow
       xyz = 305 mm upper-arm length in -Y, 7 mm Z offset.
       Negative-Z axis matches AR4 motor winding direction. -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 -0.305 0.007" rpy="0 0 3.1416"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.5533" upper="0.9076" velocity="1.0472" effort="10"/>
  </joint>

  <!-- joint_4: wrist roll
       Zero xyz — the wrist pivot is co-located with elbow output frame.
       Negative-Z axis consistent with joints 2 & 3 convention. -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0" rpy="1.5708 0 -1.5708"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.1416" upper="3.1416" velocity="1.0472" effort="5"/>
  </joint>

  <!-- joint_5: wrist pitch
       xyz = 222.63 mm forearm length in -Z (of link_4 frame).
       Unique: rotates about X axis, not Z. -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 -0.22263" rpy="3.14159 0 -1.5708"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.8326" upper="1.8326" velocity="1.0472" effort="5"/>
  </joint>

  <!-- joint_6: wrist yaw / end-effector spin
       xyz = 41 mm (l6_length from mk3.yaml).
       Back to positive-Z axis, unlike joints 2-4. -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.041" rpy="0 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" velocity="1.0472" effort="5"/>
  </joint>

  <!-- ee_joint: fixed end-effector mounting frame (no motion) -->
  <joint name="ee_joint" type="fixed">
    <parent link="link_6"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       GRIPPER — simple parallel-jaw built from
       primitives (matches the cylinder/box style of
       this file). Mounted on ee_link, opens along X.
       gripper_finger_left is the actuated joint;
       gripper_finger_right mirrors it via <mimic>.
       ═══════════════════════════════════════════ -->

  <link name="gripper_base">
    <visual>
      <geometry><box size="0.06 0.03 0.03"/></geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><box size="0.06 0.03 0.03"/></geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.07"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="ee_link"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="gripper_finger_left">
    <visual>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <link name="gripper_finger_right">
    <visual>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry><box size="0.01 0.02 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <!-- Actuated finger: positive = open, slides outward along +X.
       lower=0 (closed, jaws ~0.02 apart) upper=0.02 (open). -->
  <joint name="gripper_finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_finger_left"/>
    <origin xyz="0.01 0 0.03" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.02" velocity="0.1" effort="20"/>
  </joint>

  <!-- Right finger mirrors the left: same opening, opposite direction. -->
  <joint name="gripper_finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_finger_right"/>
    <origin xyz="-0.01 0 0.03" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.02" velocity="0.1" effort="20"/>
    <mimic joint="gripper_finger_left_joint" multiplier="1.0" offset="0"/>
  </joint>

</robot>
